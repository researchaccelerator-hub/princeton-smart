# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.0
language-settings:
  java: "17"
ignore:
  SNYK-JAVA-COMMONSIO-8161190:
    - '*':
        reason: >
          Transitive via androidx.databinding:databinding-compiler (AGP build tooling only).
          Not included in the shipped APK. Forcing the version via resolutionStrategy
          breaks the instrumented test infrastructure due to conflict with existing
          protobuf-java-util exclusions.
        expires: 2027-01-01T00:00:00.000Z
        created: 2026-02-25T00:00:00.000Z
  SNYK-JAVA-COMGOOGLEPROTOBUF-8055227:
    - '*':
        reason: >
          Transitive via com.google.testing.platform build tooling (AGP/UTP only).
          Not included in the shipped APK. Forcing protobuf-java version breaks the
          AndroidInstrumentationDriver due to conflict with existing protobuf-java-util
          exclusions in configurations.all.
        expires: 2027-01-01T00:00:00.000Z
        created: 2026-02-25T00:00:00.000Z
