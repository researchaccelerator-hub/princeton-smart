    </style>

    <style name="Theme.TestApp" parent="Base.Theme.TestApp" />

    <!-- Base application theme. -->
    <style name="Theme.Screenlake" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/screenlake_main</item>
        <item name="colorPrimaryVariant">@color/screenlake_main</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Transparent status bar — edge-to-edge content draws behind it -->
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>
