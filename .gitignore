# =============================================================================
# Credentials & Secrets
# Never commit credentials, API keys, or environment-specific configuration
# =============================================================================
local.properties
*.env
.env.*
/app/google-services.json

# =============================================================================
# Signing
# Keystores contain private keys — keep out of version control
# =============================================================================
*.keystore
*.jks
keystore.properties

# =============================================================================
# Build Outputs
# =============================================================================
/build
**/build/
*.apk
*.aab
*.ap_
*.dex

# =============================================================================
# Gradle
# =============================================================================
.gradle/
gradle-app.setting
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# =============================================================================
# Android Studio / IntelliJ IDEA
# =============================================================================
*.iml
/.idea/
.idea/
/captures
*.orig

# =============================================================================
# Native Build (CMake / NDK)
# =============================================================================
.externalNativeBuild/
.cxx/

# =============================================================================
# Test & Profiling Artifacts
# =============================================================================
*.hprof
/test-results/
/lint/
/reports/

# =============================================================================
# OS — macOS
# =============================================================================
.DS_Store

# =============================================================================
# IDE — VS Code
# =============================================================================
.vscode/settings.json

